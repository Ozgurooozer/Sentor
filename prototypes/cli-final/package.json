{
  "name": "manus-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "TypeScript tabanlı, Yerel AI destekli akıllı CLI aracı",
  "main": "dist/index.js",
  "bin": {
    "manus": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "typescript",
    "ai",
    "local-ai",
    "ollama"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^8.2.5",
    "ora": "^5.4.1",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.5",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
